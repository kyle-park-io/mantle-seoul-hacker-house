{
  "name": "mantle-contracts-hardhat",
  "version": "0.1.0",
  "description": "Mantle Contracts - Hardhat 3 workspace",
  "keywords": [
    "ethereum",
    "solidity",
    "mantle",
    "hardhat",
    "contracts"
  ],
  "license": "MIT",
  "author": "Mantle Contracts",
  "type": "module",
  "scripts": {
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "deploy:ignition:testnet": "echo y | hardhat ignition deploy ignition/modules/MantleUSDCDeploy.ts --network mantleTestnet",
    "deploy:script:testnet": "hardhat run scripts/deploy.ts --network mantleTestnet",
    "lint": "solhint 'contracts/**/*.sol' && eslint 'test/**/*.ts' 'ignition/**/*.ts' 'scripts/**/*.ts'",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint:ts": "eslint 'test/**/*.ts' 'ignition/**/*.ts' 'scripts/**/*.ts'",
    "node": "hardhat node",
    "test": "hardhat test",
    "volume:sim": "hardhat test test/mantle.volume.test.ts",
    "volume:sim:script": "hardhat run scripts/volumeSim.ts --network mantleFork"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "eth-chainlist": "^0.0.765",
    "ethers": "^6.16.0",
    "solady": "^0.1.26",
    "viem": "^2.48.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-ethers": "^4.0.11",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.8",
    "@nomicfoundation/hardhat-ignition": "^3.1.5",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.5",
    "@nomicfoundation/hardhat-ignition-viem": "^3.1.5",
    "@nomicfoundation/hardhat-keystore": "^3.0.9",
    "@nomicfoundation/hardhat-mocha": "^3.0.19",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.8",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.15",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.5",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.5",
    "@nomicfoundation/hardhat-typechain": "^3.0.9",
    "@nomicfoundation/hardhat-verify": "^3.0.17",
    "@nomicfoundation/hardhat-viem": "^3.0.7",
    "@nomicfoundation/hardhat-viem-assertions": "^3.0.11",
    "@nomicfoundation/ignition-core": "^3.1.5",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "chai": "^5.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "hardhat": "^3.4.5",
    "mocha": "^11.7.5",
    "solhint": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.0.0"
  }
}
